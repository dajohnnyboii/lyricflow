{
  "name": "lyricflow",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5199 && electron .\"",
    "electron:build": "vite build && electron-builder",

    "mobile:sync": "vite build && npx cap sync",
    "ios": "vite build && npx cap sync ios && npx cap open ios",
    "android": "vite build && npx cap sync android && npx cap open android"
  },
  "build": {
    "appId": "com.lyricflow.app",
    "productName": "LyricFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.music",
      "icon": "public/icon.png"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0",
    "wait-on": "^9.0.4"
  }
}
